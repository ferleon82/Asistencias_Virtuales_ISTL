# ================================================================
# ISTL - Sistema de Asistencia Virtual Docente
# Variables de Entorno - Copiar a .env y completar valores
# ================================================================

# --- PostgreSQL --------------------------------------------------
POSTGRES_PASSWORD=istl_dev_password

# --- Redis -------------------------------------------------------
REDIS_PASSWORD=istl_redis_dev

# --- JWT (¡Cambiar en producción! Mínimo 32 caracteres) ----------
JWT_ACCESS_SECRET=cambia_este_secreto_de_acceso_en_produccion_32chars
JWT_REFRESH_SECRET=cambia_este_secreto_de_refresh_en_produccion_32chars
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth institucional ---------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=tecnologicoloja.edu.ec
